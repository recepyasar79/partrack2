# --- Backend ---
NODE_ENV=development
PORT=3001
TZ=Europe/Istanbul

# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/parktrack

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Bootstrap admin (default site'nin site_yonetici'si — multi-tenant sonrası)
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=ChangeMeOnFirstLogin!

# Bootstrap superadmin (platform sahibi — tüm sitelere erişir, site_id=NULL).
# İlk deploy'da set edilip seed çalıştıktan sonra unset/rotate edilmeli.
BOOTSTRAP_SUPERADMIN_USER=
BOOTSTRAP_SUPERADMIN_PASS=

# Cloudflare R2 (foto storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=parktrack-photos
R2_PUBLIC_URL=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=ihlal_bildirimi

# Python OCR microservice (backend/python_ocr) - EasyOCR + OpenCV plate recognition
# Local: http://localhost:5000   Docker compose: http://python-ocr:5000   Fly.io: https://parktrack-ocr.fly.dev
PYTHON_OCR_URL=http://localhost:5000
# Cold-started Fly machines need ~30-60s to load EasyOCR weights on first hit.
# Production: 90000. Local development: 20000.
PYTHON_OCR_TIMEOUT_MS=20000
# Shared secret — OCR servisi public URL'de yaşıyor; bu key HER İKİ app'te de
# set edilince /ocr yalnız X-OCR-KEY header'ıyla çalışır (kötüye kullanım önlenir).
# Üret: openssl rand -hex 32
# Set:  fly secrets set OCR_API_KEY=... -a parktrack-ocr
#       fly secrets set OCR_API_KEY=... -a parktrack-backend
OCR_API_KEY=

# Plate Recognizer Snapshot Cloud API — cache-first OCR akışının 4. (son)
# katmanı. Python OCR + plate_learnings cache miss verirse buraya gidilir.
# FREE tier 2.500 lookup/ay, SMALL $50/ay 50.000 lookup. Hesap:
# https://platerecognizer.com
PLATE_RECOGNIZER_API_KEY=
# Opsiyonel: özel endpoint (on-premise SDK vb.). Boşsa public Snapshot Cloud.
PLATE_RECOGNIZER_API_URL=https://api.platerecognizer.com/v1/plate-reader/
# Hedef ülke kodu — Türkiye için 'tr'. Plaka formatına göre filtreleme yapar.
PLATE_RECOGNIZER_REGIONS=tr
PLATE_RECOGNIZER_TIMEOUT_MS=15000

# --- Billing / iyzico (Faz Ü3.5) ---
# Boş bırakılırsa NODE_ENV=production'da iyzico provider hata fırlatır.
# Test/dev için BILLING_PROVIDER=mock kullan.
BILLING_PROVIDER=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Sandbox: https://sandbox-api.iyzipay.com   Production: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Pricing plan reference code'ları — iyzico panelinden alınır
# (Subscription > Products > Pricing Plans).
IYZICO_PLAN_STANDART_MONTHLY=
IYZICO_PLAN_STANDART_YEARLY=
IYZICO_PLAN_PRO_MONTHLY=
IYZICO_PLAN_PRO_YEARLY=

# --- Billing / PayTR (Faz Ü3.6) ---
# PayTR Mağaza panelinden alınır. Test modunda (1) gerçek tahsilat yapılmaz.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
PAYTR_BASE_URL=https://www.paytr.com

# --- KVKK Data Retention (Faz Ü4) ---
# Hassas tablolar için saklama süresi (yıl). Boş bırakılırsa default 5.
# Cron job: npm run job:data-retention (günlük çağrılır)
RETENTION_YEARS_VIOLATIONS=5
RETENTION_YEARS_NOTIFICATIONS=5
RETENTION_YEARS_AUDIT=5
RETENTION_YEARS_OWNERHISTORY=5

# Foto retention ayrı: gunluk_kontroller + R2 fotoğrafları FOTO_KEEP_DAYS
# gün sonra silinir (default 90). Cron: npm run job:foto-temizle
FOTO_KEEP_DAYS=90

# --- Billing / Paraşüt e-fatura (Faz Ü3.7) ---
# Paraşüt OAuth (password grant). Hesap > API uygulamalarından client
# bilgisi alınır. Boş bırakılırsa invoice issuance no-op olur (DB'de
# parasut_invoice_id NULL kalır, sistem çalışmaya devam eder).
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_USERNAME=
PARASUT_PASSWORD=
PARASUT_COMPANY_ID=
PARASUT_API_URL=https://api.parasut.com

# CORS
FRONTEND_URL=http://localhost:5173

# Sentry (opsiyonel, production)
SENTRY_DSN=

# --- Frontend (VITE_ prefix gerekli) ---
VITE_API_URL=http://localhost:3000/api
VITE_SENTRY_DSN=
